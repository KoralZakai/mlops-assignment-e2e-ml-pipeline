# --- Inference (required) ---
NEBIUS_API_KEY=XXX

# --- MLflow (optional; unset -> local ./mlruns file store) ---
# MLFLOW_TRACKING_URI=http://localhost:5000

# --- DockerOperator DAG (optional) ---
# AGENT_IMAGE=mlops-agent:latest

# --- Object storage / S3 upload (optional; unset S3_BUCKET -> upload step is skipped) ---
# S3_BUCKET=my-runs-bucket
# S3_PREFIX=runs
# S3_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud
# AWS_ACCESS_KEY_ID=XXX
# AWS_SECRET_ACCESS_KEY=XXX
